{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "icon": "assets/copyblockid/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.wodichka.copyblockid.fabric.CopyBlockIdFabric"
    ]
  },
  "mixins": [
    "copyblockid.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=17",
    "fabric-api": "*"
  }
}
